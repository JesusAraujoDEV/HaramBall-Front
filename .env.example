# Backend base URL (without the /api/v1 prefix; the API client adds it).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Auto-lock timeout in milliseconds after the app backgrounds/is inactive.
EXPO_PUBLIC_LOCK_TIMEOUT_MS=60000

# Milliseconds after a Copy_Action before the clipboard is best-effort cleared.
EXPO_PUBLIC_CLIPBOARD_CLEAR_MS=20000

# Argon2id profile name. Currently only "interactive" is implemented;
# reserved for future tuning without an app update.
EXPO_PUBLIC_ARGON2_PROFILE=interactive

# Re-verification window for biometrics/passkeys in ms (default 24h).
EXPO_PUBLIC_SESSION_TTL_MS=86400000
